generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VoiceVariant {
  SYSTEM
  CUSTOM
}

enum VoiceCategory {
  AUDIOBOOK
  CONVERSATIONAL
  CUSTOMER_SERVICE
  GENERAL
  NARRATIVE
  CHARACTERS
  MEDITATION
  MOTIVATIONAL
  PODCAST
  ADVERTISING
  VOICEOVER
  CORPORATE
}

enum ProjectBlockStatus {
  DRAFT
  EDITING
  GENERATING
  GENERATED
  FAILED
}

enum ProjectExportStatus {
  PROCESSING
  READY
  FAILED
}

enum ProjectNotificationType {
  COMMENT_MENTION
}

model Voice {
  id String @id @default(cuid())

  orgId String?

  name        String
  description String?
  category    VoiceCategory @default(GENERAL)
  language    String        @default("en-US")
  variant     VoiceVariant
  r2ObjectKey String?

  generations   Generation[]
  projectBlocks ProjectBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([variant])
  @@index([orgId])
}

model Generation {
  id String @id @default(cuid())

  orgId String

  voiceId String?
  voice   Voice?  @relation(fields: [voiceId], references: [id], onDelete: SetNull)

  text              String
  voiceName         String
  r2ObjectKey       String?
  temperature       Float
  topP              Float
  topK              Int
  repetitionPenalty Float

  currentProjectBlocks  ProjectBlock[]           @relation("CurrentProjectBlockGeneration")
  projectBlockHistory   ProjectBlockGeneration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([voiceId])
}

model Project {
  id String @id @default(cuid())

  orgId String

  name        String
  description String?

  blocks        ProjectBlock[]
  exports       ProjectExport[]
  notifications ProjectNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model ProjectBlock {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  order              Int
  timelineStartMs    Int  @default(0)
  timelineDurationMs Int?

  text     String
  revision Int    @default(1)

  lockOwnerId   String?
  lockedAt      DateTime?
  lockExpiresAt DateTime?

  status ProjectBlockStatus @default(DRAFT)

  voiceId String?
  voice   Voice?  @relation(fields: [voiceId], references: [id], onDelete: SetNull)

  generationId String?
  generation   Generation? @relation("CurrentProjectBlockGeneration", fields: [generationId], references: [id], onDelete: SetNull)

  generationHistory ProjectBlockGeneration[]
  comments          ProjectComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([voiceId])
  @@index([generationId])
  @@index([lockOwnerId])
  @@index([lockExpiresAt])
}

model ProjectComment {
  id String @id @default(cuid())

  orgId String

  blockId String
  block   ProjectBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  authorId   String
  authorName String

  body               String
  mentionedUsernames String[] @default([])
  isResolved         Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([blockId, createdAt])
  @@index([authorId])
  @@index([isResolved])
}

model ProjectNotification {
  id String @id @default(cuid())

  orgId String

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  blockId   String
  commentId String

  recipientUserId   String
  recipientUsername String

  actorUserId String
  actorName   String

  type ProjectNotificationType @default(COMMENT_MENTION)

  title String
  body  String

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([projectId])
  @@index([recipientUserId, isRead, createdAt])
  @@index([commentId])
}

model ProjectBlockGeneration {
  id String @id @default(cuid())

  blockId String
  block   ProjectBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  generationId String
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([blockId, generationId])
  @@index([blockId, createdAt])
  @@index([generationId])
}

model ProjectExport {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  status       ProjectExportStatus @default(PROCESSING)
  r2ObjectKey  String?
  fileName     String
  contentType  String              @default("audio/wav")
  durationMs   Int?
  errorMessage String?
  sourceHash   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([sourceHash])
  @@index([createdAt])
}
